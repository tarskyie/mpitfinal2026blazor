@page "/"
@inject Services.ZhgutLlmService zhgutLlmService
@inject IJSRuntime JS
@using System.Text

<style>
    .chat-messages-scroll {
        height: calc(100vh - 280px);
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 12px;
        padding: 8px 4px;
    }

    .calendar-grid {
        display: grid;
        grid-template-columns: repeat(7, 1fr);
        gap: 2px;
    }

    .calendar-day-header {
        text-align: center;
        font-weight: bold;
        padding: 4px;
    }

    .calendar-day {
        border: 1px solid #e0e0e0;
        padding: 4px;
        min-height: 60px;
        position: relative;
    }

    .outside-month {
        color: #bdbdbd;
    }

    .today {
        background-color: #f0f0f0;
    }

    .day-number {
        font-size: 0.8em;
    }

    .tasks {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        margin-top: 4px;
    }

    .task-dot {
        width: 6px;
        height: 6px;
        background-color: red;
        border-radius: 50%;
        margin: 1px;
    }
    
    .marked {
        background-color: green;
    }
</style>

<MudGrid Spacing="0" Style="height: calc(100vh - 180px);">
    <!-- Chat column -->
    <MudItem xs="12" md="8" lg="9" Style="display: flex; flex-direction: column;">
        <MudPaper Elevation="0" Style="display: flex; flex-direction: column; height: 100%;">

            <!-- Messages -->
            <div class="chat-messages-scroll" id="chat-scroll">

                @if (!chatMessages.Any())
                {
                    <div style="flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; opacity: 0.45; padding-top: 60px;">
                        <MudIcon Icon="@Icons.Material.Outlined.Forum" Style="font-size: 3.5rem;" />
                        <MudText Typo="Typo.h6" Class="mt-2">Нет сообщений</MudText>
                        <MudText Typo="Typo.body2">Настройте параметры снизу и начните диалог</MudText>
                    </div>
                }

                @foreach (var item in chatMessages)
                {
                    bool isUser = item.Role == "User";
                    <div style="display: flex; justify-content: @(isUser ? "flex-end" : "flex-start"); align-items: flex-end; gap: 8px;">
                        <div>
                            <div class="@(isUser ? "bubble-user" : "bubble-assistant")">
                                @item.Role: <MudText Typo="Typo.body1">@item.Content</MudText>
                            </div>
                        </div>
                    </div>
                }

                @if (isLoading)
                {
                    <div style="display: flex; align-items: flex-end; gap: 8px;">
                        <MudAvatar Color="Color.Primary" Size="Size.Small">AI</MudAvatar>
                        <div class="bubble-assistant">
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                        </div>
                    </div>
                }

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <MudAlert Severity="Severity.Error" Dense="true" ShowCloseIcon="true"
                              CloseIconClicked="() => errorMessage = string.Empty">
                        @errorMessage
                    </MudAlert>
                }
            </div>

            <!-- Input bar -->
            <MudPaper Elevation="2" Style="padding: 10px 12px; margin-top: auto;">
                <MudStack Row="true" AlignItems="AlignItems.End" Spacing="2">
                    <MudTextField T="string"
                                  Placeholder="Введите сообщение…"
                                  @bind-Value="prompt"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  AutoGrow="true"
                                  FullWidth="true"
                                  Disabled="isLoading"
                                  OnKeyDown="HandleKeyDown"
                                  Immediate="true" />
                    <MudIconButton Icon="@Icons.Material.Filled.Send"
                                   Color="Color.Primary"
                                   Variant="Variant.Filled"
                                   Size="Size.Medium"
                                   Disabled="@(isLoading || string.IsNullOrWhiteSpace(prompt))"
                                   Style="align-self: center;"
                                   OnClick="SendMessage" />
                </MudStack>
            </MudPaper>
        </MudPaper>
        <MudPaper Elevation="1" Style="padding: 16px; overflow-y: auto;">

            <MudText Typo="Typo.subtitle1" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Settings" Size="Size.Small" Class="mr-1" />
                Настройки
            </MudText>

            <MudTextField T="string"
                          Label="Base URL"
                          Placeholder="https://api.example.com"
                          @bind-Value="url"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          FullWidth="true"
                          Class="mb-3" />

            <MudTextField T="string"
                          Label="API Key"
                          Placeholder="sk-..."
                          @bind-Value="key"
                          InputType="InputType.Password"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          FullWidth="true"
                          Class="mb-3" />

            <MudTextField T="string"
                          Label="Модель"
                          Placeholder="gpt-4o"
                          @bind-Value="model"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          FullWidth="true"
                          Class="mb-3" />

            <MudText Typo="Typo.body2" Class="mb-1">
                Температура: <strong>@temperature.ToString("0.0")</strong>
            </MudText>
            <MudSlider T="double"
                       @bind-Value="temperature"
                       Min="0.0" Max="2.0" Step="0.1"
                       Color="Color.Primary"
                       Class="mb-3" />

            <MudDivider Class="mb-3" />

            <MudButton Variant="Variant.Outlined"
                       Color="Color.Error"
                       StartIcon="@Icons.Material.Filled.DeleteSweep"
                       FullWidth="true"
                       OnClick="ClearHistory">
                Очистить историю
            </MudButton>

            @if (chatMessages.Any())
            {
                <MudText Typo="Typo.caption" Style="display:block; text-align:center; margin-top:8px; opacity:0.5;">
                    @chatMessages.Count сообщ. в истории
                </MudText>
            }

        </MudPaper>
    </MudItem>
    <MudItem xs="12" md="4" lg="3" Style="display: flex; flex-direction: column; background-color: var(--mud-palette-background-grey);">
        <MudPaper Class="pa-4 h-100">
            <MudText Typo="Typo.h4">Календарь</MudText>

            <div class="d-flex justify-space-between align-center mb-4">
                <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft" OnClick="@(() => MoveMonth(-1))" />
                <MudText Typo="Typo.h5">@_currentDate.ToString("MMMM yyyy")</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.ChevronRight" OnClick="@(() => MoveMonth(1))" />
            </div>

            <div class="calendar-grid">
                @foreach (var dayName in new[] { "Вс", "Пн", "Вт", "Ср", "Чт", "Пт", "Сб" })
                {
                    <div class="calendar-day-header">@dayName</div>
                }

                @foreach (var day in GetDaysInMonth())
                {
                    <div class="calendar-day @(day.Month != _currentDate.Month ? "outside-month" : "") @(day.Date == DateTime.Today ? "today" : "")">
                        <div class="day-number">@day.Day</div>
                        <div class="tasks">
                            @foreach (var task in GetTasksForDay(day))
                            {
                                if (task.IsDone == false)
                                {
                                    <span class="task-dot"></span>
                                }
                                else
                                {
                                    <span class="task-dot marked"></span>
                                }
                            }
                        </div>
                    </div>
                }
            </div>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    List<Services.ChatMessage> chatMessages = new();
    bool isLoading = false;
    string prompt = string.Empty;
    string model = string.Empty;
    string key = string.Empty;
    string url = string.Empty;
    string systemPrompt = "You're an AI assistant attached to a to-do tasks app. You can add, remove, and update tasks. Tasks can have due dates. Today is " + DateTime.Today.ToString("yyyy-MM-dd") + ".";
    string errorMessage = string.Empty;
    double temperature = 0.7;

    private DateTime _currentDate = DateTime.Today;
    private List<TodoItem> _tasks = new();

    bool sendButton_IsEnabled => !isLoading && !string.IsNullOrWhiteSpace(prompt);

    protected override void OnInitialized()
    {
        _tasks.Add(new TodoItem { Title = "Task 1", DueDate = DateTime.Today.AddDays(2) });
        _tasks.Add(new TodoItem { Title = "Task 2", DueDate = DateTime.Today.AddDays(2) });
        _tasks.Add(new TodoItem { Title = "Task 2", IsDone = true, DueDate = DateTime.Today.AddDays(2) });
        _tasks.Add(new TodoItem { Title = "Task 3", DueDate = DateTime.Today.AddDays(5) });
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await JS.InvokeVoidAsync("eval",
            "var el = document.getElementById('chat-scroll'); if(el) el.scrollTop = el.scrollHeight;");
    }

    private void MoveMonth(int months)
    {
        _currentDate = _currentDate.AddMonths(months);
    }

    private IEnumerable<DateTime> GetDaysInMonth()
    {
        var firstDayOfMonth = new DateTime(_currentDate.Year, _currentDate.Month, 1);
        int daysToSubtract = (int)firstDayOfMonth.DayOfWeek;
        var firstDayOfCalendar = firstDayOfMonth.AddDays(-daysToSubtract);
        
        var calendarDays = new List<DateTime>();
        for(int i = 0; i < 42; i++)
        {
            calendarDays.Add(firstDayOfCalendar.AddDays(i));
        }
        return calendarDays;
    }

    private List<TodoItem> GetTasksForDay(DateTime day)
    {
        return _tasks.Where(t => t.DueDate.HasValue && t.DueDate.Value.Date == day.Date).ToList();
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
            await SendMessage();
    }

    private void ClearHistory()
    {
        chatMessages.Clear();
        errorMessage = string.Empty;
    }

    private async Task SendMessage()
    {
        if (!sendButton_IsEnabled)
            return;

        isLoading = true;
        errorMessage = string.Empty;

        chatMessages.Add(new Services.ChatMessage { Role = "User", Content = prompt.Trim() });
        prompt = string.Empty;
        StateHasChanged();

        try
        {
            var messages = new List<Services.ChatMessage>();
            if (!string.IsNullOrWhiteSpace(systemPrompt))
                messages.Add(new Services.ChatMessage { Role = "System", Content = systemPrompt });
            
            messages.AddRange(chatMessages);
            messages.Add(new Services.ChatMessage { Role = "System", Content = $"Current unticked tasks: {GetContext()}. Current ticked tasks: {GetContext(true)}" });

            var request = new Services.ChatCompletionRequest
            {
                Model = model,
                Messages = messages,
                Temperature = temperature
            };

            var response = await zhgutLlmService.GetChatCompletionAsync(
                request: request, apiKey: key, baseUrl: url);

            if (response == null)
            {
                errorMessage = "Ответ от API не получен.";
            }
            else
            {
                var content = response.Choices[response.Choices.Count - 1].Message.Content;
                chatMessages.Add(new Services.ChatMessage { Role = "Assistant", Content = content });
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Ошибка: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private string GetContext(bool getTicked = false)
    {
        var tasksToShow = _tasks.Where(t => t.IsDone == getTicked);
        if (!tasksToShow.Any())
        {
            return "No tasks.";
        }

        var sb = new System.Text.StringBuilder();
        foreach (var task in tasksToShow)
        {
            sb.Append(task.Title);
            if (task.DueDate.HasValue)
            {
                sb.Append($" (due: {task.DueDate.Value.ToString("yyyy-MM-dd")})");
            }
            sb.Append("; ");
        }
        return sb.ToString();
    }

    public class TodoItem
    {
        public string Title { get; set; } = String.Empty;
        public bool IsDone { get; set; }
        public DateTime? DueDate { get; set; }
    }

}
