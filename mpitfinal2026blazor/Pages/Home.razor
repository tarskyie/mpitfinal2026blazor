@page "/"
@inject Services.ZhgutLlmService zhgutLlmService
@inject Services.ProfileService profileService
@inject Services.StorageService storageService
@inject IJSRuntime JS
@using System.Text
@using System.Text.Json

<style>
    .chat-messages-scroll {
        height: calc(100vh - 280px);
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 12px;
        padding: 8px 4px;
    }

    .calendar-grid {
        display: grid;
        grid-template-columns: repeat(7, 1fr);
        gap: 2px;
    }

    .calendar-day-header {
        text-align: center;
        font-weight: bold;
        padding: 4px;
    }

    .calendar-day {
        border: 1px solid #e0e0e0;
        padding: 4px;
        min-height: 60px;
        position: relative;
    }

    .outside-month {
        color: #bdbdbd;
    }

    .today {
        background-color: #f0f0f0;
    }

    .day-number {
        font-size: 0.8em;
    }

    .tasks {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        margin-top: 4px;
    }

    .task-dot {
        width: 6px;
        height: 6px;
        background-color: red;
        border-radius: 50%;
        margin: 1px;
    }

    .marked {
        background-color: green;
    }

    .group {
        background-color: gray;
    }
</style>

<MudGrid Spacing="0" Style="height: calc(100vh - 180px);">
    <!-- Chat column -->
    <MudItem xs="12" md="8" lg="9" Style="display: flex; flex-direction: column;">
        <MudPaper Elevation="0" Style="display: flex; flex-direction: column; height: 100%;">

            <!-- Messages -->
            <div class="chat-messages-scroll" id="chat-scroll">

                @if (!chatMessages.Any())
                {
                    <div style="flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; opacity: 0.45; padding-top: 60px;">
                        <MudIcon Icon="@Icons.Material.Outlined.Forum" Style="font-size: 3.5rem;" />
                        <MudText Typo="Typo.h6" Class="mt-2">Нет сообщений</MudText>
                        <MudText Typo="Typo.body2">Настройте параметры снизу и начните диалог</MudText>
                    </div>
                }

                @foreach (var item in chatMessages)
                {
                    bool isUser = item.Role == "user";
                    <div style="display: flex; justify-content: @(isUser ? "flex-end" : "flex-start"); align-items: flex-end; gap: 8px;">
                        <div>
                            <div class="@(isUser ? "bubble-user" : "bubble-assistant")">
                                @item.Role: <MudText Typo="Typo.body1">@item.Content</MudText>
                            </div>
                        </div>
                    </div>
                }

                @if (isLoading)
                {
                    <div style="display: flex; align-items: flex-end; gap: 8px;">
                        <MudAvatar Color="Color.Primary" Size="Size.Small">AI</MudAvatar>
                        <div class="bubble-assistant">
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                        </div>
                    </div>
                }

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <MudAlert Severity="Severity.Error" Dense="true" ShowCloseIcon="true"
                              CloseIconClicked="() => errorMessage = string.Empty">
                        @errorMessage
                    </MudAlert>
                }
            </div>

            <!-- Input bar -->
            <MudPaper Elevation="2" Style="padding: 10px 12px; margin-top: auto;">
                <MudStack Row="true" AlignItems="AlignItems.End" Spacing="2">
                    <MudTextField T="string"
                                  Placeholder="Введите сообщение…"
                                  @bind-Value="prompt"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  AutoGrow="true"
                                  FullWidth="true"
                                  Disabled="isLoading"
                                  OnKeyDown="HandleKeyDown"
                                  Immediate="true" />
                    <MudIconButton Icon="@Icons.Material.Filled.Send"
                                   Color="Color.Primary"
                                   Variant="Variant.Filled"
                                   Size="Size.Medium"
                                   Disabled="@(isLoading || string.IsNullOrWhiteSpace(prompt))"
                                   Style="align-self: center;"
                                   OnClick="SendMessage" />
                </MudStack>
            </MudPaper>
        </MudPaper>
        <MudPaper Elevation="1" Style="padding: 16px; overflow-y: auto;">

            <MudText Typo="Typo.subtitle1" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Settings" Size="Size.Small" Class="mr-1" />
                Настройки
            </MudText>

            <MudTextField T="string"
                          Label="Base URL"
                          Placeholder="https://api.example.com"
                          @bind-Value="url"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          FullWidth="true"
                          Class="mb-3" />

            <MudTextField T="string"
                          Label="API Key"
                          Placeholder="sk-..."
                          @bind-Value="key"
                          InputType="InputType.Password"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          FullWidth="true"
                          Class="mb-3" />

            <MudTextField T="string"
                          Label="Модель"
                          Placeholder="gpt-4o"
                          @bind-Value="model"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          FullWidth="true"
                          Class="mb-3" />

            <MudText Typo="Typo.body2" Class="mb-1">
                Температура: <strong>@temperature.ToString("0.0")</strong>
            </MudText>
            <MudSlider T="double"
                       @bind-Value="temperature"
                       Min="0.0" Max="2.0" Step="0.1"
                       Color="Color.Primary"
                       Class="mb-3" />

            <MudDivider Class="mb-3" />

            <MudButton Variant="Variant.Outlined"
                       Color="Color.Secondary"
                       StartIcon="@Icons.Material.Filled.Refresh"
                       FullWidth="true"
                       Class="mb-2"
                       OnClick="RefreshGroupTasks">
                Обновить задания групп
            </MudButton>

            <MudButton Variant="Variant.Outlined"
                       Color="Color.Error"
                       StartIcon="@Icons.Material.Filled.DeleteSweep"
                       FullWidth="true"
                       OnClick="ClearHistory">
                Очистить историю
            </MudButton>

            @if (chatMessages.Any())
            {
                <MudText Typo="Typo.caption" Style="display:block; text-align:center; margin-top:8px; opacity:0.5;">
                    @chatMessages.Count сообщ. в истории
                </MudText>
            }

        </MudPaper>
    </MudItem>

    <!-- Calendar column -->
    <MudItem xs="12" md="4" lg="3" Style="display: flex; flex-direction: column; background-color: var(--mud-palette-background-grey);">
        <MudPaper Class="pa-4 h-100">
            <MudText Typo="Typo.h4">Календарь</MudText>

            <div class="d-flex justify-space-between align-center mb-4">
                <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft" OnClick="@(() => MoveMonth(-1))" />
                <MudText Typo="Typo.h5">@_currentDate.ToString("MMMM yyyy")</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.ChevronRight" OnClick="@(() => MoveMonth(1))" />
            </div>

            <div class="calendar-grid">
                @foreach (var dayName in new[] { "Вс", "Пн", "Вт", "Ср", "Чт", "Пт", "Сб" })
                {
                    <div class="calendar-day-header">@dayName</div>
                }

                @foreach (var day in GetDaysInMonth())
                {
                    <div class="calendar-day @(day.Month != _currentDate.Month ? "outside-month" : "") @(day.Date == DateTime.Today ? "today" : "")">
                        <div class="day-number">@day.Day</div>
                        <div class="tasks">
                            @* Personal tasks — red / green *@
                            @foreach (var task in GetTasksForDay(day))
                            {
                                <span class="task-dot @(task.IsDone ? "marked" : "")"></span>
                            }
                            @* Group tasks — gray *@
                            @foreach (var _ in GetGroupTasksForDay(day))
                            {
                                <span class="task-dot group"></span>
                            }
                        </div>
                    </div>
                }
            </div>

            @if (_groupTasks.Any())
            {
                <MudText Typo="Typo.caption" Class="mt-2" Style="opacity:0.6;">
                    ● серые — задания из групп (их @_groupTasks.Count)
                </MudText>
            }
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    List<Services.ChatMessage> chatMessages = new();
    bool isLoading = false;
    string prompt = string.Empty;
    string model = string.Empty;
    string key = string.Empty;
    string url = string.Empty;
    string errorMessage = string.Empty;
    double temperature = 0.7;

    string? refreshToken;
    string studentAccessToken = string.Empty;

    private DateTime _currentDate = DateTime.Today;
    private List<TodoItem> _tasks = new();
    private List<Services.GroupTaskItem> _groupTasks = new();

    private string BuildSystemPrompt() =>
        $"""
        You are an AI assistant attached to a student task-tracker app. Today is {DateTime.Today:yyyy-MM-dd}.

        PERSONAL TASKS (shown in the chat context)
        You can add, remove, and update personal tasks that appear on the calendar as red/green dots.

        GROUP TASKS (shown in the chat context as read-only context)
        Group tasks are fetched automatically from the server and shown as GRAY dots on the calendar.
        You cannot create or delete group tasks — only the teacher can do that.

        STUDENT COMMANDS
        When the user explicitly asks you to perform one of the following actions, reply with a
        PLAIN TEXT explanation to the user AND append the corresponding command block at the very
        end of your message (after all prose). Do not emit a command unless the user clearly
        requested that action.

        Supported commands (append verbatim at the end of your reply, one per action):

        1. Join a group:
           [CMD:JOIN_GROUP group_id=<id> invite_code=<code>]

        2. Submit a solution for a task:
           [CMD:SUBMIT_SOLUTION task_id=<id> text=<solution text here>]

        Rules:
        - Extract group_id, invite_code, task_id, and text from what the user tells you.
        - If a required value is missing, ask the user for it instead of guessing.
        - Only emit ONE command per reply.
        - Do not wrap commands in code fences.
        """;

    protected override void OnInitialized()
    {
        chatMessages.Add(new Services.ChatMessage { Role = "assistant", Content = "Hello! Welcome to the task tracker app." });
    }

    protected override async Task OnInitializedAsync()
    {
        refreshToken = await storageService.GetItemAsync<string>("refresh_token");
        if (!string.IsNullOrEmpty(refreshToken))
        {
            string accessToken = await profileService.GetAccessToken(refreshToken);
            if (!string.IsNullOrEmpty(accessToken))
            {
                studentAccessToken = accessToken;
                await RefreshGroupTasks();
            }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await JS.InvokeVoidAsync("eval",
            "var el = document.getElementById('chat-scroll'); if(el) el.scrollTop = el.scrollHeight;");
    }

    private void MoveMonth(int months) => _currentDate = _currentDate.AddMonths(months);

    private IEnumerable<DateTime> GetDaysInMonth()
    {
        var firstDayOfMonth = new DateTime(_currentDate.Year, _currentDate.Month, 1);
        int daysToSubtract = (int)firstDayOfMonth.DayOfWeek;
        var firstDayOfCalendar = firstDayOfMonth.AddDays(-daysToSubtract);
        for (int i = 0; i < 42; i++)
            yield return firstDayOfCalendar.AddDays(i);
    }

    private List<TodoItem> GetTasksForDay(DateTime day) =>
        _tasks.Where(t => t.DueDate.HasValue && t.DueDate.Value.Date == day.Date).ToList();

    private List<Services.GroupTaskItem> GetGroupTasksForDay(DateTime day) =>
        _groupTasks.Where(t => t.ExpirationDate.HasValue && t.ExpirationDate.Value.Date == day.Date).ToList();

    private async Task RefreshGroupTasks()
    {
        if (string.IsNullOrWhiteSpace(studentAccessToken)) return;
        _groupTasks = await profileService.GetAllStudentGroupTasks(studentAccessToken);
        StateHasChanged();
    }

    private string GetPersonalTaskContext(bool getTicked = false)
    {
        var tasksToShow = _tasks.Where(t => t.IsDone == getTicked);
        if (!tasksToShow.Any()) return "No tasks.";

        var sb = new StringBuilder();
        foreach (var task in tasksToShow)
        {
            sb.Append(task.Title);
            if (task.DueDate.HasValue)
                sb.Append($" (due: {task.DueDate.Value:yyyy-MM-dd})");
            sb.Append("; ");
        }
        return sb.ToString();
    }

    private string GetGroupTaskContext()
    {
        if (!_groupTasks.Any()) return "No group tasks.";
        var sb = new StringBuilder();
        foreach (var gt in _groupTasks)
        {
            sb.Append($"[Group: {gt.GroupName}, Task ID: {gt.TaskId}] {gt.Title}");
            if (gt.ExpirationDate.HasValue)
                sb.Append($" (due: {gt.ExpirationDate.Value:yyyy-MM-dd})");
            sb.Append("; ");
        }
        return sb.ToString();
    }

    // Command parser & executor
    /// <summary>
    /// Scans the AI reply for [CMD:...] blocks, executes them, and returns
    /// a status string to append to the assistant message (or empty string).
    /// The original command token is stripped from displayContent.
    /// </summary>
    private async Task<(string CleanContent, string StatusLine)> ProcessCommands(string rawContent)
    {
        const string joinPrefix = "[CMD:JOIN_GROUP ";
        const string submitPrefix = "[CMD:SUBMIT_SOLUTION ";

        string clean = rawContent;
        string status = string.Empty;

        // Join group
        int joinStart = rawContent.IndexOf(joinPrefix);
        if (joinStart >= 0)
        {
            int joinEnd = rawContent.IndexOf(']', joinStart);
            if (joinEnd > joinStart)
            {
                string cmdBody = rawContent.Substring(joinStart + joinPrefix.Length, joinEnd - joinStart - joinPrefix.Length);
                clean = rawContent.Remove(joinStart, joinEnd - joinStart + 1).Trim();

                int groupId = ExtractInt(cmdBody, "group_id");
                string inviteCode = ExtractString(cmdBody, "invite_code");

                if (groupId > 0 && !string.IsNullOrEmpty(inviteCode) && !string.IsNullOrEmpty(studentAccessToken))
                {
                    var (success, msg) = await profileService.JoinGroup(studentAccessToken, groupId, inviteCode);
                    if (success)
                    {
                        status = $"\nВы успешно вступили в группу {groupId}.";
                        await RefreshGroupTasks(); // pull new group's tasks onto the calendar
                    }
                    else
                    {
                        status = $"\nОшибка вступления в группу: {msg}";
                    }
                }
                else
                {
                    status = "\nДля команды JOIN_GROUP нужен токен студента, group_id и invite_code.";
                }
            }
        }

        // Submit solution
        int submitStart = rawContent.IndexOf(submitPrefix);
        if (submitStart >= 0)
        {
            int submitEnd = rawContent.IndexOf(']', submitStart);
            if (submitEnd > submitStart)
            {
                string cmdBody = rawContent.Substring(submitStart + submitPrefix.Length, submitEnd - submitStart - submitPrefix.Length);
                clean = rawContent.Remove(submitStart, submitEnd - submitStart + 1).Trim();

                int taskId = ExtractInt(cmdBody, "task_id");
                string solutionText = ExtractString(cmdBody, "text");

                if (taskId > 0 && !string.IsNullOrEmpty(solutionText) && !string.IsNullOrEmpty(studentAccessToken))
                {
                    var (success, msg) = await profileService.SubmitSolution(studentAccessToken, taskId, solutionText);
                    status = success
                        ? $"\nРешение для задания {taskId} отправлено."
                        : $"\nОшибка отправки решения: {msg}";
                }
                else
                {
                    status = "\nДля команды SUBMIT_SOLUTION нужен токен студента, task_id и text.";
                }
            }
        }

        return (clean, status);
    }

    // Parsing helpers
    private static int ExtractInt(string body, string key)
    {
        // Looks for key=<value> where value is digits (stops at space or end)
        string search = key + "=";
        int idx = body.IndexOf(search);
        if (idx < 0) return 0;
        idx += search.Length;
        int end = idx;
        while (end < body.Length && char.IsDigit(body[end])) end++;
        return int.TryParse(body.Substring(idx, end - idx), out int v) ? v : 0;
    }

    private static string ExtractString(string body, string key)
    {
        // Looks for key=<rest of string> (value runs to the next key= or end)
        string search = key + "=";
        int idx = body.IndexOf(search);
        if (idx < 0) return string.Empty;
        idx += search.Length;
        // Value ends at the next recognized key or at the end
        int end = body.Length;
        foreach (var nextKey in new[] { " group_id=", " invite_code=", " task_id=", " text=" })
        {
            int ni = body.IndexOf(nextKey, idx);
            if (ni > idx && ni < end) end = ni;
        }
        return body.Substring(idx, end - idx).Trim();
    }

    // Handle message sending
    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
            await SendMessage();
    }

    private void ClearHistory()
    {
        chatMessages.Clear();
        errorMessage = string.Empty;
    }

    private async Task SendMessage()
    {
        if (isLoading || string.IsNullOrWhiteSpace(prompt)) return;

        isLoading = true;
        errorMessage = string.Empty;

        chatMessages.Add(new Services.ChatMessage { Role = "user", Content = prompt.Trim() });
        StateHasChanged();

        try
        {
            var messages = new List<Services.ChatMessage>
            {
                new() { Role = "system", Content = BuildSystemPrompt() },
                new() { Role = "assistant", Content = "Hello! Welcome to the task tracker app." },
                new() { Role = "user",      Content = prompt.Trim() },
                // Inject task context invisibly so the model knows what's there
                new()
                {
                    Role = "system",
                    Content = $"[App context — not shown to the user]\n" +
                              $"Personal tasks (pending): {GetPersonalTaskContext()}\n" +
                              $"Personal tasks (done): {GetPersonalTaskContext(true)}\n" +
                              $"Group tasks (read-only): {GetGroupTaskContext()}\n" +
                              $"Client date: {DateTime.Today:yyyy-MM-dd}"
                }
            };

            prompt = string.Empty;

            if (!string.IsNullOrEmpty(refreshToken))
            {
                string accessToken = await profileService.GetAccessToken(refreshToken);
                if (!string.IsNullOrEmpty(accessToken))
                {
                    studentAccessToken = accessToken;
                    await RefreshGroupTasks(); // optionally load group tasks immediately
                }
            }

            var request = new Services.ChatCompletionRequest
            {
                Model = model,
                Messages = messages,
                Temperature = temperature
            };

            var response = await zhgutLlmService.GetChatCompletionAsync(request: request, apiKey: key, baseUrl: url);
            //var response = new Services.ChatCompletionResponse();
            //prompt = await zhgutLlmService.GetChatCompletionDebugAsync(request: request, apiKey: key, baseUrl: url);

            if (response == null)
            {
                errorMessage = "Ответ от API не получен.";
            }
            else
            {
                var rawContent = response.Choices[response.Choices.Count - 1].Message.Content;
                var (cleanContent, statusLine) = await ProcessCommands(rawContent);
                chatMessages.Add(new Services.ChatMessage
                {
                    Role = "assistant",
                    Content = cleanContent + statusLine
                });
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Ошибка: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    public class TodoItem
    {
        public string Title { get; set; } = string.Empty;
        public bool IsDone { get; set; }
        public DateTime? DueDate { get; set; }
    }
}
