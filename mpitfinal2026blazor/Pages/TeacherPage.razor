@page "/teacher"
@inject Services.ProfileService profileService
@inject Services.StorageService storageService
@inject NavigationManager navigationManager
@using System.Text.Json

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8">
    <MudText Typo="Typo.h3" GutterBottom="true">Страница учителя</MudText>

    <MudGrid>
        <MudItem xs="12" md="4">
            <MudPaper Elevation="3" Class="pa-4 flex-grow-1" Style="height: 80vh; display: flex; flex-direction: column;">
                <MudText Typo="Typo.h5" Class="mb-4">Группы</MudText>

                <MudTextField @bind-Value="_name" T="string"
                              Label="Название новой группы"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Adornment="Adornment.End"
                              AdornmentIcon="@Icons.Material.Filled.Add"
                              OnAdornmentClick="AddGroup"
                              Class="mb-1" />

                <div style="overflow-y: auto; flex-grow: 1;">
                    @foreach (var group in _groupList)
                    {
                        @if (group.Teacher != teacherId)
                        {
                            continue;
                        }

                        <MudCard Elevation="@(selectedGroup?.Id == group.Id ? 6 : 1)"
                                 Class="@($"mb-3 {(selectedGroup?.Id == group.Id ? "border-solid border-2 mud-border-primary" : "")}")"
                                 @onclick="() => SelectGroup(group)"
                                 Style="cursor: pointer; transition: 0.3s;">
                            <MudCardHeader>
                                <CardHeaderContent>
                                    <MudText Typo="Typo.h6">@group.Name (ID: @group.Id)</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Код приглашения: @group.InviteCode</MudText>
                                </CardHeaderContent>
                                <CardHeaderActions>
                                    <MudIconButton Icon="@Icons.Material.Filled.ChevronRight" Color="Color.Default" />
                                </CardHeaderActions>
                            </MudCardHeader>
                        </MudCard>
                    }
                </div>

                @if (!string.IsNullOrEmpty(statusText))
                {
                    <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2">@statusText</MudAlert>
                }
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="8">
            @if (selectedGroup != null)
            {
                <MudPaper Elevation="3" Class="pa-6">
                    <div class="d-flex align-center justify-space-between mb-6">
                        <div>
                            <MudText Typo="Typo.h4">@selectedGroup.Name</MudText>
                            <MudText Typo="Typo.subtitle1" Color="Color.Secondary">Управление задачами и проверка решений</MudText>
                        </div>
                        <MudButton StartIcon="@Icons.Material.Filled.Close" Variant="Variant.Text" Color="Color.Error" OnClick="ClearSelectedGroup">Закрыть</MudButton>
                    </div>

                    <MudTabs Elevation="0" Outlined="true" PanelClass="pa-4">
                        <MudTabPanel Text="Задачи" Icon="@Icons.Material.Filled.List">
                            <MudTable Items="_tasks" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="0">
                                <HeaderContent>
                                    <MudTh>Название</MudTh>
                                    <MudTh>Дедлайн</MudTh>
                                    <MudTh>Действия</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd DataLabel="Название">@context.Title</MudTd>
                                    <MudTd DataLabel="Дедлайн">
                                        <MudChip T="string" Icon="@Icons.Material.Filled.Event" Size="Size.Small">
                                            @context.ExpirationDate.ToString("yyyy-MM-dd")
                                        </MudChip>
                                    </MudTd>
                                    <MudTd>
                                        <MudButton Variant="Variant.Filled"
                                                   Color="Color.Info"
                                                   Size="Size.Small"
                                                   OnClick="() => ViewSolutions(context)">Решения</MudButton>
                                    </MudTd>
                                </RowTemplate>
                            </MudTable>

                            <MudPaper Variant="Variant.Outlined" Class="pa-4 mt-6">
                                <MudText Typo="Typo.subtitle2" Class="mb-2">Создать новую задачу</MudText>
                                <MudGrid Spacing="2" Justify="Justify.FlexEnd">
                                    <MudItem xs="12" sm="6">
                                        <MudTextField @bind-Value="_taskTitle" Label="Название задачи" Variant="Variant.Filled" Margin="Margin.Dense" />
                                    </MudItem>
                                    <MudItem xs="12" sm="4">
                                        <MudDatePicker Date="_taskDeadline"
                                                       DateChanged="@((DateTime? date) => OnDeadlineChanged(date))"
                                                       Label="Дедлайн"
                                                       Variant="Variant.Filled"
                                                       Margin="Margin.Dense" />
                                    </MudItem>
                                    <MudItem xs="12" sm="2" Class="d-flex align-center">
                                        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" OnClick="CreateTask">Добавить</MudButton>
                                    </MudItem>
                                </MudGrid>
                            </MudPaper>
                        </MudTabPanel>
                    </MudTabs>

                    @if (solutionsVisible)
                    {
                        <MudCard Elevation="4" Class="mt-6 animated fadeIn" Style="border-top: 4px solid var(--mud-palette-primary);">
                            <MudCardHeader>
                                <CardHeaderContent>
                                    <MudText Typo="Typo.h6">Проверка решений: @_selectedTask?.Title</MudText>
                                </CardHeaderContent>
                                <CardHeaderActions>
                                    <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="HideSolutions" />
                                </CardHeaderActions>
                            </MudCardHeader>
                            <MudCardContent>
                                <MudTable Items="_solutions" Dense="true" Hover="true" Elevation="0">
                                    <HeaderContent>
                                        <MudTh>Ученик</MudTh>
                                        <MudTh>Текст</MudTh>
                                        <MudTh>Статус</MudTh>
                                        <MudTh>Дата</MudTh>
                                        <MudTh Style="width: 200px;">Оценка</MudTh>
                                    </HeaderContent>
                                    <RowTemplate>
                                        <MudTd>@context.StudentId</MudTd>
                                        <MudTd>@context.Text</MudTd>
                                        <MudTd>
                                            @if (context.Grade.HasValue)
                                            {
                                                <MudChip T="string" Color="Color.Success" Size="Size.Small" Variant="Variant.Text">Оценено: @context.Grade</MudChip>
                                            }
                                            else
                                            {
                                                <MudChip T="string" Color="Color.Warning" Size="Size.Small" Variant="Variant.Text">Ожидает</MudChip>
                                            }
                                        </MudTd>
                                        <MudTd>@context.SubmittedAt.ToString("g")</MudTd>
                                        <MudTd>
                                            <div class="d-flex align-center gap-2">
                                                <MudNumericField T="int?"
                                                                 Value="@_pendingGrades.GetValueOrDefault(context.Id)"
                                                                 ValueChanged="@((int? v) => _pendingGrades[context.Id] = v)"
                                                                 Variant="Variant.Outlined" Margin="Margin.Dense"
                                                                 Min="1" Max="5" Style="width: 60px;" />
                                                <MudIconButton Icon="@Icons.Material.Filled.CheckCircle"
                                                               Color="Color.Primary"
                                                               Disabled="@(!_pendingGrades.ContainsKey(context.Id) || !_pendingGrades[context.Id].HasValue)"
                                                               OnClick="() => GradeSolution(context)" />
                                            </div>
                                        </MudTd>
                                    </RowTemplate>
                                </MudTable>
                                @if (!string.IsNullOrEmpty(_gradeStatusText))
                                {
                                    <MudAlert Severity="@_gradeAlertSeverity" Class="mt-4" Variant="Variant.Outlined" Dense="true">@_gradeStatusText</MudAlert>
                                }
                            </MudCardContent>
                        </MudCard>
                    }
                </MudPaper>
            }
            else
            {
                <div class="d-flex flex-column align-center justify-center mud-height-full" style="opacity: 0.5; min-height: 400px;">
                    <MudText Typo="Typo.h5">Выберите группу из списка, чтобы начать работу</MudText>
                </div>
            }
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    List<Group> _groupList = new();
    string _name = string.Empty;
    string? statusText = string.Empty;
    string accessToken = string.Empty;
    int? teacherId;

    Group? selectedGroup = null;
    List<mpitfinal2026blazor.Models.TaskModel> _tasks = new();
    string _taskTitle = string.Empty;
    DateTime _taskDeadline = DateTime.Today;
    mpitfinal2026blazor.Models.TaskModel? _selectedTask = null;
    List<mpitfinal2026blazor.Models.SolutionModel> _solutions = new();
    bool solutionsVisible = false;

    // Grading state: maps solution ID → pending grade value
    Dictionary<int, int?> _pendingGrades = new();
    string _gradeStatusText = string.Empty;
    Severity _gradeAlertSeverity = Severity.Normal;

    protected override void OnInitialized()
    {
        base.OnInitialized();
        _groupList = new List<Group>();
    }

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        string? refreshToken = await storageService.GetItemAsync<string>("refresh_token");
        if (refreshToken != null)
        {
            accessToken = await profileService.GetAccessToken(refreshToken);

            JsonElement? myself = await profileService.GetYourself(accessToken);
            if (myself == null)
            {
                navigationManager.NavigateTo("/");
                return;
            }
            JsonElement concreteMe = myself ?? default;
            teacherId = concreteMe.GetProperty("id").GetInt32();

            statusText = await profileService.GetGroups(accessToken);
            if (statusText != null)
            {
                try
                {
                    var options = new JsonSerializerOptions
                    {
                        PropertyNamingPolicy = JsonNamingPolicy.SnakeCaseLower
                    };
                    _groupList.AddRange(JsonSerializer.Deserialize<List<Group>>(statusText, options) ?? new());
                    statusText = "Deserialization complete.";
                }
                catch (Exception ex)
                {
                    statusText += "An error has occured: " + ex.Message;
                }
            }
            StateHasChanged();
        }
    }

    private async Task AddGroup()
    {
        statusText = await profileService.CreateGroup(accessToken, _name);
    }

    private async void SelectGroup(Group group)
    {
        selectedGroup = group;
        await LoadTasks();
        StateHasChanged();
    }

    private void ClearSelectedGroup()
    {
        selectedGroup = null;
        _tasks.Clear();
        solutionsVisible = false;
    }

    private async Task LoadTasks()
    {
        if (selectedGroup == null) return;
        var json = await profileService.GetTasks(accessToken, selectedGroup.Id);
        if (json != null)
        {
            try
            {
                var options = new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.SnakeCaseLower };
                _tasks = JsonSerializer.Deserialize<List<mpitfinal2026blazor.Models.TaskModel>>(json, options) ?? new();
            }
            catch { _tasks = new(); }
        }
    }

    private async void CreateTask()
    {
        if (selectedGroup == null) return;
        await profileService.CreateTask(accessToken, _taskTitle, selectedGroup.Id, _taskDeadline);
        await LoadTasks();
        _taskTitle = string.Empty;
        _taskDeadline = DateTime.Today;
        StateHasChanged();
    }

    private async void ViewSolutions(mpitfinal2026blazor.Models.TaskModel task)
    {
        _solutions.Clear();
        _selectedTask = task;
        _pendingGrades.Clear();
        _gradeStatusText = string.Empty;
        var json = await profileService.GetSolutionsForTask(accessToken, task.Id);
        if (json != null)
        {
            try
            {
                var options = new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.SnakeCaseLower };
                var solutions = JsonSerializer.Deserialize<List<mpitfinal2026blazor.Models.SolutionModel>>(json, options) ?? new();
                // Pre-fill pending grades with existing grades so teacher sees current value
                foreach (var s in solutions)
                {
                    if (s.Grade.HasValue)
                    {
                        _pendingGrades[s.Id] = s.Grade;
                    }
                    if (s.TaskId == task.Id)
                    {
                        _solutions.Add(s);
                    }
                }
                solutionsVisible = true;
            }
            catch { _solutions = new(); solutionsVisible = false; }
        }
        StateHasChanged();
    }

    private void HideSolutions()
    {
        solutionsVisible = false;
        _selectedTask = null;
        _solutions.Clear();
        _pendingGrades.Clear();
        _gradeStatusText = string.Empty;
    }

    private async Task GradeSolution(mpitfinal2026blazor.Models.SolutionModel solution)
    {
        if (!_pendingGrades.TryGetValue(solution.Id, out var grade) || !grade.HasValue)
            return;

        var result = await profileService.GradeSolution(accessToken, solution.Id, grade.Value);
        if (result)
        {
            solution.Grade = grade;
            _gradeStatusText = $"Оценка {grade} сохранена для студента {solution.StudentId}.";
            _gradeAlertSeverity = Severity.Success;
        }
        else
        {
            _gradeStatusText = "Не удалось сохранить оценку. Попробуйте ещё раз.";
            _gradeAlertSeverity = Severity.Error;
        }
        StateHasChanged();
    }

    private void OnDeadlineChanged(DateTime? date)
    {
        if (date.HasValue)
            _taskDeadline = date.Value;
    }

    public class Group
    {
        public int Id { get; set; }
        public string Name { get; set; } = string.Empty;
        public int Teacher { get; set; }
        public List<int> Students { get; set; } = new();
        public string InviteCode { get; set; } = string.Empty;
    }
}