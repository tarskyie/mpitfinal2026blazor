@page "/teacher"
@inject Services.ProfileService profileService
@inject Services.StorageService storageService
@using System.Text.Json

<MudText Typo="Typo.h3">Страница учителя</MudText>
<MudText Typo="Typo.h5">Группы</MudText>
<MudPaper Class="pa-4 h-25" Style="overflow: scroll;">
    <MudText Typo="Typo.h5">Список задач</MudText>
    <MudTextField @bind-Value="_name" T="string" Label="Новая группа" Variant="Variant.Outlined"
        Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Add" OnAdornmentClick="AddGroup" />

    @foreach (var group in _groupList)
    {
        <div style="margin-bottom: 16px;">
            <MudText Typo="Typo.h6">@group.Name (@group.InviteCode)</MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="() => SelectGroup(group)">Выбрать</MudButton>
        </div>
    }
</MudPaper>
@statusText

<MudPaper Class="pa-4 mt-4">
    @if (selectedGroup != null)
    {
        <MudText Typo="Typo.h5">Задачи группы: @selectedGroup.Name</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Secondary" OnClick="ClearSelectedGroup">Скрыть</MudButton>
        <MudTable Items="_tasks">
            <HeaderContent>
                <MudTh>Название</MudTh>
                <MudTh>Дедлайн</MudTh>
                <MudTh>Действия</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.Title</MudTd>
                <MudTd>@context.ExpirationDate.ToString("yyyy-MM-dd")</MudTd>
                <MudTd>
                    <MudButton Variant="Variant.Outlined" OnClick="() => ViewSolutions(context)">Решения</MudButton>
                </MudTd>
            </RowTemplate>
        </MudTable>
        <MudTextField @bind-Value="_taskTitle" Label="Название задачи" />
        <MudDatePicker Date="_taskDeadline" DateChanged="@((DateTime? date) => OnDeadlineChanged(date))" Label="Дедлайн" />
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="CreateTask">Создать задачу</MudButton>
    }

    @if (solutionsVisible)
    {
        <MudPaper Class="pa-4 mt-2">
            <MudText Typo="Typo.h6">Решения задачи: @_selectedTask?.Title</MudText>
            <MudButton Variant="Variant.Text" OnClick="HideSolutions">Скрыть решения</MudButton>
            <MudTable Items="_solutions">
                <HeaderContent>
                    <MudTh>Студент</MudTh>
                    <MudTh>Текст</MudTh>
                    <MudTh>Оценка</MudTh>
                    <MudTh>Дата сдачи</MudTh>
                    <MudTh>Выставить оценку</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.StudentId</MudTd>
                    <MudTd>@context.Text</MudTd>
                    <MudTd>
                        @if (context.Grade.HasValue)
                        {
                            <MudChip T="string" Color="Color.Success" Size="Size.Small">@context.Grade</MudChip>
                        }
                        else
                        {
                            <MudChip T="string" Color="Color.Default" Size="Size.Small">—</MudChip>
                        }
                    </MudTd>
                    <MudTd>@context.SubmittedAt.ToString("g")</MudTd>
                    <MudTd>
                        <div style="display: flex; align-items: center; gap: 8px;">
                            <MudNumericField T="int?"
                                Value="@_pendingGrades.GetValueOrDefault(context.Id)"
                                ValueChanged="@((int? v) => _pendingGrades[context.Id] = v)"
                                Label="Оценка" Min="1" Max="5"
                                Style="width: 90px;" />
                            <MudButton Variant="Variant.Filled"
                                Color="Color.Primary"
                                Size="Size.Small"
                                Disabled="@(!_pendingGrades.ContainsKey(context.Id) || !_pendingGrades[context.Id].HasValue)"
                                OnClick="() => GradeSolution(context)">
                                Сохранить
                            </MudButton>
                        </div>
                    </MudTd>
                </RowTemplate>
            </MudTable>
            @if (!string.IsNullOrEmpty(_gradeStatusText))
            {
                <MudAlert Severity="@_gradeAlertSeverity" Class="mt-2">@_gradeStatusText</MudAlert>
            }
        </MudPaper>
    }
</MudPaper>

@code {
    List<Group> _groupList = new();
    string _name = string.Empty;
    string? statusText = string.Empty;
    string accessToken = string.Empty;

    Group? selectedGroup = null;
    List<mpitfinal2026blazor.Models.TaskModel> _tasks = new();
    string _taskTitle = string.Empty;
    DateTime _taskDeadline = DateTime.Today;
    mpitfinal2026blazor.Models.TaskModel? _selectedTask = null;
    List<mpitfinal2026blazor.Models.SolutionModel> _solutions = new();
    bool solutionsVisible = false;

    // Grading state: maps solution ID → pending grade value
    Dictionary<int, int?> _pendingGrades = new();
    string _gradeStatusText = string.Empty;
    Severity _gradeAlertSeverity = Severity.Normal;

    protected override void OnInitialized()
    {
        base.OnInitialized();
        _groupList = new List<Group>();
    }

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        string? refreshToken = await storageService.GetItemAsync<string>("refresh_token");
        if (refreshToken != null)
        {
            accessToken = await profileService.GetAccessToken(refreshToken);
            statusText = await profileService.GetGroups(accessToken);
            if (statusText != null)
            {
                try
                {
                    var options = new JsonSerializerOptions
                    {
                        PropertyNamingPolicy = JsonNamingPolicy.SnakeCaseLower
                    };
                    _groupList = JsonSerializer.Deserialize<List<Group>>(statusText, options);
                    statusText = "Deserialization complete.";
                }
                catch (Exception ex)
                {
                    statusText += "An error has occured: " + ex.Message;
                }
            }
            StateHasChanged();
        }
    }

    private async Task AddGroup()
    {
        statusText = await profileService.CreateGroup(accessToken, _name);
    }

    private async void SelectGroup(Group group)
    {
        selectedGroup = group;
        await LoadTasks();
        StateHasChanged();
    }

    private void ClearSelectedGroup()
    {
        selectedGroup = null;
        _tasks.Clear();
        solutionsVisible = false;
    }

    private async Task LoadTasks()
    {
        if (selectedGroup == null) return;
        var json = await profileService.GetTasks(accessToken, selectedGroup.Id);
        if (json != null)
        {
            try
            {
                var options = new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.SnakeCaseLower };
                _tasks = JsonSerializer.Deserialize<List<mpitfinal2026blazor.Models.TaskModel>>(json, options) ?? new();
            }
            catch { _tasks = new(); }
        }
    }

    private async void CreateTask()
    {
        if (selectedGroup == null) return;
        await profileService.CreateTask(accessToken, _taskTitle, selectedGroup.Id, _taskDeadline);
        await LoadTasks();
        _taskTitle = string.Empty;
        _taskDeadline = DateTime.Today;
        StateHasChanged();
    }

    private async void ViewSolutions(mpitfinal2026blazor.Models.TaskModel task)
    {
        _selectedTask = task;
        _pendingGrades.Clear();
        _gradeStatusText = string.Empty;
        var json = await profileService.GetSolutionsForTask(accessToken, task.Id);
        if (json != null)
        {
            try
            {
                var options = new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.SnakeCaseLower };
                _solutions = JsonSerializer.Deserialize<List<mpitfinal2026blazor.Models.SolutionModel>>(json, options) ?? new();
                // Pre-fill pending grades with existing grades so teacher sees current value
                foreach (var s in _solutions)
                    if (s.Grade.HasValue)
                        _pendingGrades[s.Id] = s.Grade;
                solutionsVisible = true;
            }
            catch { _solutions = new(); solutionsVisible = false; }
        }
        StateHasChanged();
    }

    private void HideSolutions()
    {
        solutionsVisible = false;
        _selectedTask = null;
        _solutions.Clear();
        _pendingGrades.Clear();
        _gradeStatusText = string.Empty;
    }

    private async Task GradeSolution(mpitfinal2026blazor.Models.SolutionModel solution)
    {
        if (!_pendingGrades.TryGetValue(solution.Id, out var grade) || !grade.HasValue)
            return;

        var result = await profileService.GradeSolution(accessToken, solution.Id, grade.Value);
        if (result)
        {
            solution.Grade = grade;
            _gradeStatusText = $"Оценка {grade} сохранена для студента {solution.StudentId}.";
            _gradeAlertSeverity = Severity.Success;
        }
        else
        {
            _gradeStatusText = "Не удалось сохранить оценку. Попробуйте ещё раз.";
            _gradeAlertSeverity = Severity.Error;
        }
        StateHasChanged();
    }

    private void OnDeadlineChanged(DateTime? date)
    {
        if (date.HasValue)
            _taskDeadline = date.Value;
    }

    public class Group
    {
        public int Id { get; set; }
        public string Name { get; set; } = string.Empty;
        public int Teacher { get; set; }
        public List<int> Students { get; set; } = new();
        public string InviteCode { get; set; } = string.Empty;
    }
}